            </VBox>
            <StackPane prefHeight="61.0" prefWidth="387.0">
               <children>
                  <Button fx:id="complete_order" maxHeight="43.0" mnemonicParsing="false" onAction="#completeOrder" prefHeight="43.0" prefWidth="200.0" styleClass="complete-order-btn" stylesheets="@../assets/order.css" text="Complete order">
                     <StackPane.margin>
                        <Insets bottom="10.0" />
                     </StackPane.margin>
                  </Button>
               </children>
            </StackPane>
         </children>
      </VBox>
   </children>
</StackPane>
