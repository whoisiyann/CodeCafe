<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<StackPane fx:id="orderCard" prefHeight="356.0" prefWidth="389.0" styleClass="order" stylesheets="@../assets/order.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codecafe_KDS.controller.OrderCardController">
   <children>
      <VBox prefHeight="200.0" prefWidth="100.0">
         <children>
            <HBox prefHeight="56.0" prefWidth="387.0">
               <children>
                  <Label text="ORDER">
                     <font>
                        <Font size="25.0" />
                     </font>
                     <HBox.margin>
                        <Insets left="20.0" top="10.0" />
                     </HBox.margin>
                  </Label>
                  <Label fx:id="order_NUMBER" text="#00001">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="25.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <Separator prefWidth="200.0" stylesheets="@../assets/order.css" />
            <StackPane prefHeight="47.0" prefWidth="387.0">
               <children>
                  <Label fx:id="dineIn_takeOut" text="DINE-IN">
                     <font>
                        <Font size="25.0" />
                     </font>
                  </Label>
               </children>
            </StackPane>
            <VBox fx:id="itemsContainer" alignment="TOP_LEFT" prefHeight="204.0" prefWidth="367.0">
