<AnchorPane prefHeight="1080.0" prefWidth="1920.0" styleClass="background" stylesheets="@../assets/KDS.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codecafe_KDS.controller.KitchenDisplayController">
   <children>
      <AnchorPane prefHeight="116.0" prefWidth="1930.0" styleClass="top" stylesheets="@../assets/KDS.css">
