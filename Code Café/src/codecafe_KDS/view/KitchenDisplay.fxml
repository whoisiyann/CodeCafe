            <Label layoutX="75.0" layoutY="14.0" styleClass="top-label" stylesheets="@../assets/KDS.css" text="Orders" />
         </children>
      </AnchorPane>
      <GridPane fx:id="ordersGrid" hgap="50.0" layoutX="127.0" layoutY="173.0" prefHeight="822.0" prefWidth="1666.0" vgap="50.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints maxHeight="401.0" minHeight="10.0" prefHeight="393.0" vgrow="SOMETIMES" />
